#!/bin/bash
# prerm — runs before the .deb package is removed
set -e

# ---------------------------------------------------------------------------
# Remove auditd rules installed by Lab Guardian
# ---------------------------------------------------------------------------
RULES_FILE="/etc/audit/rules.d/lab_guardian_exam.rules"

if [ -f "$RULES_FILE" ]; then
    rm -f "$RULES_FILE"
    echo "[OK] Removed auditd rules: ${RULES_FILE}"
fi

# Reload auditd rules (remove exam rules from kernel)
if command -v augenrules > /dev/null 2>&1; then
    augenrules --load 2>/dev/null || true
elif command -v auditctl > /dev/null 2>&1; then
    auditctl -D 2>/dev/null || true  # flush all rules
fi

# Reload the auditd service if running
if command -v systemctl > /dev/null 2>&1 && systemctl is-active --quiet auditd 2>/dev/null; then
    systemctl restart auditd 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Update desktop application database
# ---------------------------------------------------------------------------
if command -v update-desktop-database > /dev/null 2>&1; then
    update-desktop-database /usr/share/applications 2>/dev/null || true
fi

echo "[OK] Lab Guardian pre-removal cleanup complete."
